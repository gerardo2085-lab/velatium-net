---
import Base from '../layouts/Base.astro';
---
<Base title="Literacy — Admin" protected={true} adminOnly={true}>
  <div class="topbar">
    <div class="logo">
      <div class="logo-mark" style="width:32px;height:32px;">
        <svg class="logo-arcs" viewBox="0 0 48 48" fill="none">
          <path d="M24 36 Q12 24 24 12" stroke="#333" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M24 40 Q8 24 24 8" stroke="#222" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M24 44 Q4 24 24 4" stroke="#1a1a1a" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M24 36 Q36 24 24 12" stroke="#333" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M24 40 Q40 24 24 8" stroke="#222" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M24 44 Q44 24 24 4" stroke="#1a1a1a" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        </svg>
        <span class="logo-n" style="font-size:20px;">N</span>
      </div>
    </div>
    <div class="topbar-right"><a href="/shelf">← Library</a></div>
  </div>

  <div style="padding:0 20px 40px;">
    <div class="admin-tabs">
      <button class="tab-btn active" id="tab-access" onclick="showTab('access')">Access Requests</button>
      <button class="tab-btn" id="tab-catalog" onclick="showTab('catalog')">Catalog</button>
      <button class="tab-btn" id="tab-themes" onclick="showTab('themes')">Themes</button>
    </div>

    <div id="panel-access">
      <div class="card">
        <div id="users-list"><p style="color:var(--text-muted);font-size:13px;">Loading…</p></div>
      </div>
    </div>

    <div id="panel-catalog" style="display:none;">
      <div class="card" style="margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;gap:12px;">
        <div>
          <div style="font-size:13px;font-weight:600;">Library Scan</div>
          <div style="font-size:11px;color:var(--text-secondary);">Detect new folders in the server library and add them automatically.</div>
        </div>
        <button class="btn-sm approve" id="scan-btn" onclick="scanLibrary()" style="white-space:nowrap;">Scan Library</button>
      </div>
      <div id="scan-result" style="display:none;margin-bottom:12px;font-size:12px;padding:10px 14px;background:var(--bg-input);border-radius:8px;"></div>
      <div class="card">
        <div id="books-list"><p style="color:var(--text-muted);font-size:13px;">Loading…</p></div>
      </div>
    </div>

    <div id="panel-themes" style="display:none;">
      <div class="card">
        <p style="font-size:12px;color:var(--text-secondary);margin-bottom:20px;">Select a theme. New themes can be added by dropping a CSS file into <code style="color:var(--text-muted)">public/themes/</code> and deploying.</p>
        <div id="themes-list"><p style="color:var(--text-muted);font-size:13px;">Loading…</p></div>
      </div>
    </div>
  </div>

  <script>
    const API   = window.API;
    const token = sessionStorage.getItem('literacy_token');

    function showTab(name) {
      ['access','catalog','themes'].forEach(t => {
        document.getElementById(`panel-${t}`).style.display = name === t ? 'block' : 'none';
        document.getElementById(`tab-${t}`).classList.toggle('active', name === t);
      });
    }
    window.showTab = showTab;

    async function apiCall(url, method = 'GET', body = null) {
      const opts = { method, headers: { 'X-Session-Token': token } };
      if (body) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
      return fetch(`${API}${url}`, opts);
    }

    const STATUS_LABEL = { pending: 'Pending', active: 'Active', rejected: 'Rejected' };
    const STATUS_COLOR = { pending: 'var(--text-secondary)', active: 'var(--text-primary)', rejected: 'var(--text-muted)' };

    async function loadUsers() {
      const res   = await apiCall('/admin/users');
      const users = await res.json();
      if (!users.length) {
        document.getElementById('users-list').innerHTML = '<p style="color:var(--text-muted);font-size:13px;">No users yet.</p>';
        return;
      }
      const order = { pending: 0, active: 1, rejected: 2 };
      users.sort((a, b) => (order[a.status] ?? 9) - (order[b.status] ?? 9));
      document.getElementById('users-list').innerHTML = users.map(u => `
        <div class="user-row">
          <div style="flex:1;min-width:0;">
            <div style="font-size:14px;font-weight:600;">${u.username}</div>
            <div style="font-size:12px;color:var(--text-secondary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${u.email}</div>
            <div style="font-size:11px;color:var(--text-muted);">${new Date(u.created_at).toLocaleDateString()}</div>
          </div>
          <div class="row-actions" style="flex-shrink:0;">
            <span class="badge" style="color:${STATUS_COLOR[u.status] || 'inherit'}">${STATUS_LABEL[u.status] || u.status}</span>
            ${u.status === 'pending' ? `
              <button class="btn-sm approve" onclick="approveUser(${u.id})">Approve</button>
              <button class="btn-sm reject"  onclick="rejectUser(${u.id})">Reject</button>
            ` : u.status === 'active' ? `
              <button class="btn-sm reject" onclick="deleteUser(${u.id}, '${u.username}')">Delete</button>
            ` : `
              <button class="btn-sm" onclick="approveUser(${u.id})">Approve</button>
              <button class="btn-sm reject" onclick="deleteUser(${u.id}, '${u.username}')">Delete</button>
            `}
          </div>
        </div>`).join('');
    }

    async function loadBooks() {
      const res = await apiCall('/admin/catalog');
      const books = await res.json();
      if (!books.length) {
        document.getElementById('books-list').innerHTML = '<p style="color:var(--text-muted);font-size:13px;">No books yet.</p>';
        return;
      }
      document.getElementById('books-list').innerHTML = books.map(b => `
        <div class="book-row">
          <img src="${API}/covers/${b.slug}" onerror="this.style.display='none'"
            style="width:36px;height:54px;object-fit:cover;border-radius:4px;background:var(--bg-input);" />
          <div style="flex:1;min-width:0;">
            <div style="font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${b.title}</div>
            <div style="font-size:11px;color:var(--text-secondary);">${b.author}</div>
            <div style="font-size:10px;color:var(--text-muted);">${b.chapter_count} chapters · ${new Date(b.date_added).toLocaleDateString()}</div>
          </div>
          <div class="row-actions" style="flex-shrink:0;flex-wrap:wrap;gap:4px;">
            <span class="badge ${b.status}">${b.status}</span>
            <button class="btn-sm" onclick="fetchCover('${b.slug}', this)" title="Auto-fetch cover from Open Library / Google Books">↓ Cover</button>
            <label class="btn-sm" style="cursor:pointer;" title="Upload cover image from your device">
              ↑ Cover
              <input type="file" accept="image/*" style="display:none;" onchange="uploadCover('${b.slug}', this)">
            </label>
            ${b.chapter_count <= 1 ? `<button class="btn-sm" onclick="reExtract('${b.slug}', this)" title="Re-extract chapters from embedded metadata">Chapters</button>` : ''}
            <button class="btn-sm" onclick="toggleBook('${b.slug}')">${b.status === 'ready' ? 'Hide' : 'Show'}</button>
          </div>
        </div>`).join('');
    }

    window.approveUser = async (id) => {
      await apiCall(`/admin/users/${id}/approve`, 'POST');
      loadUsers();
    };
    window.rejectUser = async (id) => {
      await apiCall(`/admin/users/${id}/reject`, 'POST');
      loadUsers();
    };
    window.deleteUser = async (id, name) => {
      if (!confirm(`Delete user "${name}"? This cannot be undone.`)) return;
      await apiCall(`/admin/users/${id}`, 'DELETE');
      loadUsers();
    };
    window.toggleBook = async (slug) => {
      await apiCall(`/admin/books/${slug}/toggle`, 'POST');
      loadBooks();
    };
    window.uploadCover = async (slug, input) => {
      const file = input.files[0];
      if (!file) return;
      const label = input.parentElement;
      const orig  = label.childNodes[0].textContent;
      label.childNodes[0].textContent = '…';
      const form = new FormData();
      form.append('file', file);
      try {
        const res = await fetch(`${API}/admin/books/${slug}/upload-cover`, {
          method: 'POST',
          headers: { 'X-Session-Token': token },
          body: form,
        });
        if (res.ok) {
          label.childNodes[0].textContent = '✓';
          setTimeout(() => loadBooks(), 800);
        } else {
          const d = await res.json();
          label.childNodes[0].textContent = orig;
          alert(d.error || 'Upload failed');
        }
      } catch {
        label.childNodes[0].textContent = orig;
      }
    };
    window.reExtract = async (slug, btn) => {
      btn.disabled = true; btn.textContent = '…';
      try {
        const res = await apiCall(`/admin/books/${slug}/re-extract-chapters`, 'POST');
        const d   = await res.json();
        if (res.ok && d.chapters > 1) {
          btn.textContent = `✓ ${d.chapters} ch`;
          setTimeout(() => loadBooks(), 1200);
        } else {
          btn.disabled = false; btn.textContent = 'Chapters';
          alert(d.error || `Only ${d.chapters} chapter found — no embedded chapters in file.`);
        }
      } catch {
        btn.disabled = false; btn.textContent = 'Chapters';
      }
    };
    window.fetchCover = async (slug, btn) => {
      const orig = btn.textContent;
      btn.disabled = true;
      btn.textContent = '…';
      try {
        const res = await apiCall(`/admin/books/${slug}/fetch-cover`, 'POST');
        if (res.ok) {
          btn.textContent = '✓';
          setTimeout(() => loadBooks(), 800);
        } else {
          const d = await res.json();
          btn.textContent = orig;
          btn.disabled = false;
          alert(d.error || 'Cover fetch failed');
        }
      } catch {
        btn.textContent = orig;
        btn.disabled = false;
      }
    };

    window.scanLibrary = async () => {
      const btn = document.getElementById('scan-btn');
      const result = document.getElementById('scan-result');
      btn.disabled = true;
      btn.textContent = 'Scanning…';
      result.style.display = 'none';
      try {
        const res = await apiCall('/admin/scan', 'POST');
        const d   = await res.json();
        const lines = [];
        if (d.added?.length)   lines.push(`✅ Added (${d.added.length}): ${d.added.map(b => b.title).join(', ')}`);
        if (d.skipped?.length) lines.push(`⏭ Already in library (${d.skipped.length}): ${d.skipped.map(b => b.title).join(', ')}`);
        if (d.errors?.length)  lines.push(`⚠️ Errors: ${d.errors.map(e => e.folder + ' — ' + e.reason).join(', ')}`);
        if (!lines.length)     lines.push('No new folders found in the library.');
        result.innerHTML = lines.join('<br>');
        result.style.display = 'block';
        if (d.added?.length) loadBooks();
      } catch(e) {
        result.innerHTML = '❌ Scan failed: ' + e.message;
        result.style.display = 'block';
      }
      btn.disabled = false;
      btn.textContent = 'Scan Library';
    };

    async function loadThemes() {
      const res = await apiCall('/config/theme');
      const d   = await res.json();
      document.getElementById('themes-list').innerHTML = d.available.map(t => `
        <div class="user-row">
          <div>
            <div style="font-size:14px;font-weight:600;">${t.name}</div>
            <div style="font-size:12px;color:var(--text-secondary);">${t.description}</div>
          </div>
          <div class="row-actions">
            ${d.active === t.id
              ? '<span class="badge ready">Active</span>'
              : `<button class="btn-sm" onclick="setTheme('${t.id}')">Apply</button>`}
          </div>
        </div>`).join('');
    }

    window.setTheme = async (id) => {
      await apiCall('/config/theme', 'POST', { theme: id });
      document.getElementById('theme-css').href = `/themes/${id}.css`;
      loadThemes();
    };

    loadUsers();
    loadBooks();
    loadThemes();
  </script>
</Base>
