---
import Base from '../layouts/Base.astro';
---
<Base title="Literacy — Player" protected={true}>
  <div class="player-container">
    <div class="topbar" style="width:100%;padding:16px 20px;">
      <div class="logo">
        <div class="logo-mark" style="width:32px;height:32px;">
          <svg class="logo-arcs" viewBox="0 0 48 48" fill="none">
            <path d="M24 36 Q12 24 24 12" stroke="#333" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M24 40 Q8 24 24 8" stroke="#222" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M24 44 Q4 24 24 4" stroke="#1a1a1a" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M24 36 Q36 24 24 12" stroke="#333" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M24 40 Q40 24 24 8" stroke="#222" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M24 44 Q44 24 24 4" stroke="#1a1a1a" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
          <span class="logo-n" style="font-size:20px;">N</span>
        </div>
      </div>
    </div>

    <div id="player-title" class="player-title">Loading…</div>
    <div id="player-author" class="player-author"></div>

    <img id="player-cover" class="player-cover"
      src="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='280' height='280' viewBox='0 0 280 280'><rect width='280' height='280' fill='%231a1a1a'/></svg>"
      alt="Cover" />

    <div id="chapter-label" class="chapter-label">CHAPTER 1</div>

    <div class="time-row" style="width:100%;max-width:360px;">
      <span id="time-elapsed">0:00</span>
      <span id="buffer-label" style="font-size:10px;color:var(--text-muted);display:none;">Buffering…</span>
      <span id="time-total">0:00</span>
    </div>
    <div class="seek-bar" id="seek-bar" style="max-width:360px;">
      <div class="seek-fill" id="seek-fill" style="width:0%"></div>
      <div id="buffer-fill" style="position:absolute;top:0;left:0;height:100%;background:var(--border);border-radius:2px;width:0%;pointer-events:none;z-index:0;"></div>
      <div id="seek-thumb" style="position:absolute;top:50%;left:0%;transform:translate(-50%,-50%);width:14px;height:14px;background:var(--accent);border-radius:50%;pointer-events:none;z-index:3;transition:left 0.1s linear;"></div>
    </div>

    <div class="controls">
      <button class="ctrl-btn" id="btn-prev" title="Previous chapter">⏮</button>
      <button class="ctrl-btn" id="btn-back" title="Skip back 15s">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.41"/>
          <text x="8" y="17" font-size="5" fill="white" stroke="none">15</text>
        </svg>
      </button>
      <button class="ctrl-btn ctrl-btn-lg" id="btn-play">▶</button>
      <button class="ctrl-btn" id="btn-fwd" title="Skip forward 15s">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-.49-3.41"/>
          <text x="8" y="17" font-size="5" fill="white" stroke="none">15</text>
        </svg>
      </button>
      <button class="ctrl-btn" id="btn-next" title="Next chapter">⏭</button>
    </div>

    <div class="secondary-controls">
      <button class="sec-btn" id="btn-chapters">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        Chapters
      </button>
      <button class="sec-btn" id="btn-speed">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <span id="speed-label">1×</span>
      </button>
    </div>

    <div id="chapters-panel" style="display:none;width:100%;max-width:360px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-md);max-height:300px;overflow-y:auto;" class="card"></div>
  </div>

  <script>
    let API, token, slug;

    let book = null, chapters = [], currentChapter = 1, playbackRate = 1;
    // Use the persistent global audio element from Base.astro
    const audio = document.getElementById('global-audio') || new Audio();
    window.__audio = audio;
    const speeds = [0.75, 1, 1.25, 1.5, 2];
    let speedIdx = 1;

    const $ = id => document.getElementById(id);

    function fmt(s) {
      if (!s || isNaN(s)) return '0:00';
      const m = Math.floor(s / 60), sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2,'0')}`;
    }

    function audioUrl(n) {
      return `${API}/books/${slug}/chapters/${n}/audio?token=${encodeURIComponent(token)}`;
    }

    async function getAudioSrc(n) {
      try {
        const root = await navigator.storage.getDirectory();
        const dir  = await root.getDirectoryHandle(`book-${slug}`);
        const fh   = await dir.getFileHandle(`ch-${n}.mp3`);
        return URL.createObjectURL(await fh.getFile());
      } catch {
        return audioUrl(n);
      }
    }

    async function downloadChapter(n) {
      try {
        const root = await navigator.storage.getDirectory();
        const dir  = await root.getDirectoryHandle(`book-${slug}`, { create: true });
        try { await dir.getFileHandle(`ch-${n}.mp3`); return; } catch {}  // already cached
        const res = await fetch(audioUrl(n));
        const fh  = await dir.getFileHandle(`ch-${n}.mp3`, { create: true });
        const w   = await fh.createWritable();
        await res.body.pipeTo(w);
      } catch {}
    }

    function ttsPlay(text, lang = 'en') {
      speechSynthesis.cancel();
      const u = new SpeechSynthesisUtterance(text);
      u.lang = lang; u.rate = playbackRate * 0.95;
      speechSynthesis.speak(u);
    }

    async function loadChapter(n) {
      currentChapter = n;
      const ch = chapters.find(c => c.number === n);
      if (!ch) return;
      const chapterLabel = `CHAPTER ${n}${ch.title ? ': ' + ch.title : ''}`;
      $('chapter-label').textContent = chapterLabel;
      if (book && window.__updateMiniPlayer) window.__updateMiniPlayer(slug, book.title, chapterLabel);
      window.__currentChapter = n;
      audio.pause();
      if (ch.audio_path !== null || ch.duration_seconds) {
        const src = await getAudioSrc(n);
        audio.src = src;
        audio.playbackRate = playbackRate;
        audio.play().catch(() => {});
        if (n + 1 <= chapters.length) downloadChapter(n + 1);
      } else if (ch.body) {
        ttsPlay(ch.body, book.language || 'en');
      }
    }

    async function saveProgress(pos, completed = false) {
      fetch(`${API}/progress`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Session-Token': token },
        body: JSON.stringify({ slug, chapter_number: currentChapter, position: pos, completed }),
      }).catch(() => {});
    }

    function setBuffering(on) {
      $('buffer-label').style.display = on ? 'inline' : 'none';
      $('btn-play').style.opacity = on ? '0.4' : '1';
    }

    audio.addEventListener('timeupdate', () => {
      $('time-elapsed').textContent = fmt(audio.currentTime);
      $('time-total').textContent   = fmt(audio.duration);
      const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      $('seek-fill').style.width = pct + '%';
      $('seek-thumb').style.left = pct + '%';
      // buffered range indicator
      if (audio.buffered.length && audio.duration) {
        const buffEnd = audio.buffered.end(audio.buffered.length - 1);
        $('buffer-fill').style.width = ((buffEnd / audio.duration) * 100) + '%';
      }
    });
    audio.addEventListener('waiting',    () => setBuffering(true));
    audio.addEventListener('stalled',    () => setBuffering(true));
    audio.addEventListener('canplay',    () => setBuffering(false));
    audio.addEventListener('playing',    () => setBuffering(false));
    audio.addEventListener('loadstart',  () => setBuffering(true));
    audio.addEventListener('loadeddata', () => setBuffering(false));
    audio.addEventListener('play',  () => { $('btn-play').textContent = '⏸'; setBuffering(false); });
    audio.addEventListener('pause', () => { $('btn-play').textContent = '▶'; setBuffering(false); });
    audio.addEventListener('ended', () => {
      saveProgress(audio.duration, true);
      if (currentChapter < chapters.length) loadChapter(currentChapter + 1);
    });

    function seekToX(clientX) {
      if (!audio.duration) return;
      const r = $('seek-bar').getBoundingClientRect();
      const pct = Math.max(0, Math.min(1, (clientX - r.left) / r.width));
      audio.currentTime = pct * audio.duration;
    }
    function wireControls() {
      const seekBar = $('seek-bar');
      if (!seekBar) return;
      // Clone nodes to drop stale listeners from previous view-transition render
      const newSeekBar = seekBar.cloneNode(true);
      seekBar.parentNode.replaceChild(newSeekBar, seekBar);

      newSeekBar.addEventListener('click', (e) => seekToX(e.clientX));
      newSeekBar.addEventListener('touchstart', (e) => { e.preventDefault(); seekToX(e.touches[0].clientX); }, { passive: false });
      newSeekBar.addEventListener('touchmove',  (e) => { e.preventDefault(); seekToX(e.touches[0].clientX); }, { passive: false });

      $('btn-play').addEventListener('click', () => {
        if (audio.paused) audio.play().catch(() => {});
        else audio.pause();
      });
      $('btn-back').addEventListener('click', () => { audio.currentTime = Math.max(0, audio.currentTime - 15); });
      $('btn-fwd').addEventListener('click',  () => { audio.currentTime = Math.min(audio.duration || 0, audio.currentTime + 15); });
      $('btn-prev').addEventListener('click', () => { if (currentChapter > 1) loadChapter(currentChapter - 1); });
      $('btn-next').addEventListener('click', () => { if (currentChapter < chapters.length) loadChapter(currentChapter + 1); });

      $('btn-speed').addEventListener('click', () => {
        speedIdx = (speedIdx + 1) % speeds.length;
        playbackRate = speeds[speedIdx];
        audio.playbackRate = playbackRate;
        $('speed-label').textContent = playbackRate + '×';
      });

      $('btn-chapters').addEventListener('click', () => {
        const panel = $('chapters-panel');
        if (panel.style.display === 'none') {
          panel.innerHTML = chapters.map(ch =>
            `<div onclick="window.loadCh(${ch.number})" style="padding:12px 16px;border-bottom:1px solid var(--border);cursor:pointer;font-size:13px;color:${ch.number===currentChapter?'var(--text-primary)':'var(--text-secondary)'}">
              <span style="font-weight:700;margin-right:8px;">${ch.number}</span>${ch.title || 'Chapter ' + ch.number}
            </div>`
          ).join('');
          panel.style.display = 'block';
        } else {
          panel.style.display = 'none';
        }
      });
      window.loadCh = (n) => { $('chapters-panel').style.display = 'none'; loadChapter(n); };
    }

    setInterval(() => { if (!audio.paused) saveProgress(audio.currentTime); }, 10000);
    document.addEventListener('visibilitychange', () => { if (document.hidden && !audio.paused) saveProgress(audio.currentTime); });

    function onPageLoad() {
      API   = window.API;
      token = sessionStorage.getItem('literacy_token');
      slug  = new URLSearchParams(location.search).get('slug');
      if (!slug) { location.href = '/shelf'; return; }
      book = null; chapters = [];
      wireControls();
      init();
    }
    document.addEventListener('astro:page-load', onPageLoad);

    async function init() {
      try {
        const [bRes, cRes, pRes] = await Promise.all([
          fetch(`${API}/books/${slug}`,          { headers: { 'X-Session-Token': token } }),
          fetch(`${API}/books/${slug}/chapters`, { headers: { 'X-Session-Token': token } }),
          fetch(`${API}/progress/${slug}`,       { headers: { 'X-Session-Token': token } }),
        ]);
        if (!bRes.ok) { location.href = '/shelf'; return; }
        localStorage.setItem('literacy_last_slug', slug);
        book     = await bRes.json();
        chapters = await cRes.json();
        const prog = pRes.ok ? await pRes.json() : {};
        $('player-title').textContent  = book.title;
        $('player-author').textContent = book.author;
        if (book.cover_path) $('player-cover').src = `${API}/covers/${book.slug}`;

        // If returning to player for the same book — sync UI only, never restart
        if (window.__audioSlug === slug) {
          currentChapter = window.__currentChapter || 1;
          const ch = chapters.find(c => c.number === currentChapter);
          if (ch) $('chapter-label').textContent = `CHAPTER ${currentChapter}${ch.title ? ': ' + ch.title : ''}`;
          $('player-title').textContent  = book.title;
          $('player-author').textContent = book.author;
          if (book.cover_path) $('player-cover').src = `${API}/covers/${book.slug}`;
          $('btn-play').textContent = audio.paused ? '▶' : '⏸';
          setBuffering(false);
          return;
        }

        const startChapter = prog.chapter_id
          ? (chapters.find(c => c.id === prog.chapter_id)?.number || 1)
          : 1;
        await loadChapter(startChapter);
        if (prog.position) audio.currentTime = prog.position;
      } catch { location.href = '/shelf'; }
    }
    // First load — astro:page-load won't fire for the initial render
    onPageLoad();
  </script>
</Base>
